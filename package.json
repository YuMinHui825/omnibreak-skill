{
  "name": "omnibreak-skill",
  "version": "0.4.0-beta",
  "description": "OmniBreak CLI — remote Linux debugger for automated workflows and Claude Code",
  "bin": {
    "omnibreak": "./out/cli.js"
  },
  "scripts": {
    "compile": "tsc",
    "watch": "tsc --watch",
    "start": "node out/cli.js",
    "pretest:integration": "pkill -f 'node.*daemon' 2>/dev/null; sleep 0.5; nohup node out/daemon.js > /dev/null 2>&1 & sleep 2",
    "test:integration": "jest --forceExit --detectOpenHandles test/integration",
    "posttest:integration": "pkill -f 'node.*daemon' 2>/dev/null || true",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --forceExit test/unit"
  },
  "keywords": [
    "debug",
    "gdb",
    "remote",
    "linux",
    "arm64",
    "cli",
    "claude-code"
  ],
  "author": "shibu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YuMinHui825/omnibreak-skill"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/ssh2": "^1.15.5",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.4.0"
  }
}
